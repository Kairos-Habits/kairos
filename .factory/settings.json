{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'KAIROS_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || echo \"$FACTORY_PROJECT_DIR\")\"; \"$KAIROS_ROOT\"/.factory/hooks/session-start.sh'",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'KAIROS_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || echo \"$FACTORY_PROJECT_DIR\")\"; \"$KAIROS_ROOT\"/.factory/hooks/format.sh'",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash -c 'KAIROS_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || echo \"$FACTORY_PROJECT_DIR\")\"; \"$KAIROS_ROOT\"/.factory/hooks/validate.sh'",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
